# Port Websocket
WEBSOCKET_PORT_PENGGUNA=8008
WEBSOCKET_PORT_SELLER=8009
WEBSOCKET_PORT_KURIR=8010

# Path Handshake
PENGGUNA_PATH_HANDSHAKE=/pengguna/notification
SELLER_PATH_HANDSHAKE=/seller/notification
KURIR_PATH_HANDSHAKE=/kurir/notification

# Port API In-Notification
API_IN_NOTIFIKASI_PORT=8011

# Path Notifikasi Masuk
PENGGUNA_PATH_NOTIFIKASI_MASUK=/pengguna/in-notification
SELLER_PATH_NOTIFIKASI_MASUK=/seller/in-notification
KURIR_PATH_NOTIFIKASI_MASUK=/kurir/in-notification
SISTEM_PATH_NOTIFIKASI_MASUK=/sistem/in-notification

# Cassandra Database
CASS_ARCHIVE_SPACEKEY=archive_db
CASS_ARCHIVE_USER=cassandra
CASS_ARCHIVE_PASS=cassandra
CASS_ARCHIVE_PORT=9044

# Redis Cache
RDS_HOST=localhost
RDS_PORT=6379
RDS_SESSION=1